<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/8.0.171"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.proxylauncher.ui.MainController"
            styleClass="app-shell">
    <padding>
        <Insets top="18" right="18" bottom="18" left="18"/>
    </padding>

    <top>
        <VBox spacing="4" styleClass="page-header" BorderPane.alignment="CENTER_LEFT">
            <children>
                <Label styleClass="page-title" text="Proxy Launcher"/>
                <Label styleClass="page-subtitle"
                       text="Launch Windows applications with optional proxy environment variables injected into the child process."
                       wrapText="true"/>
            </children>
        </VBox>
    </top>

    <center>
        <SplitPane dividerPositions="0.32" styleClass="content-split" BorderPane.alignment="CENTER">
            <items>
                <VBox minWidth="280" prefWidth="340" spacing="16" styleClass="panel-card">
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="12">
                            <children>
                                <VBox spacing="2" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label styleClass="section-title" text="Applications"/>
                                        <Label fx:id="appCountLabel" styleClass="section-subtitle" text="0 saved entries"/>
                                    </children>
                                </VBox>
                            </children>
                        </HBox>

                        <FlowPane hgap="10" vgap="10" styleClass="button-row">
                            <children>
                                <Button mnemonicParsing="false"
                                        onAction="#handleAddApp"
                                        styleClass="secondary-button"
                                        text="Add App"/>
                                <Button fx:id="editAppButton"
                                        mnemonicParsing="false"
                                        onAction="#handleEditApp"
                                        styleClass="secondary-button"
                                        text="Edit"/>
                                <Button fx:id="deleteAppButton"
                                        mnemonicParsing="false"
                                        onAction="#handleDeleteApp"
                                        styleClass="danger-button"
                                        text="Delete"/>
                            </children>
                        </FlowPane>

                        <Label styleClass="helper-text"
                               text="Maintain a reusable list of launch targets, then drag entries to reorder them for quick access."
                               wrapText="true"/>

                        <ListView fx:id="appListView" styleClass="app-list-view" VBox.vgrow="ALWAYS"/>
                    </children>
                </VBox>

                <ScrollPane fitToWidth="true"
                            hbarPolicy="NEVER"
                            styleClass="content-scroll">
                    <content>
                        <VBox spacing="16" styleClass="details-stack">
                            <children>
                                <VBox spacing="14" styleClass="panel-card">
                                    <children>
                                        <HBox alignment="CENTER_LEFT" spacing="12">
                                            <children>
                                                <VBox spacing="2" HBox.hgrow="ALWAYS">
                                                    <children>
                                                        <Label styleClass="section-title" text="Selected Application"/>
                                                        <Label styleClass="section-subtitle"
                                                               text="Review the saved executable path, arguments, and notes before launching."
                                                               wrapText="true"/>
                                                    </children>
                                                </VBox>
                                                <Label fx:id="selectionStateLabel"
                                                       styleClass="state-pill state-pill-empty"
                                                       text="No selection"/>
                                            </children>
                                        </HBox>

                                        <GridPane hgap="12" vgap="12">
                                            <columnConstraints>
                                                <ColumnConstraints minWidth="116"/>
                                                <ColumnConstraints hgrow="ALWAYS"/>
                                            </columnConstraints>
                                            <children>
                                                <Label styleClass="field-label" text="Name" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                                                <TextField fx:id="selectedNameField"
                                                           editable="false"
                                                           promptText="Choose an application from the list"
                                                           GridPane.columnIndex="1"
                                                           GridPane.rowIndex="0"/>

                                                <Label styleClass="field-label" text="Executable" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                                                <TextField fx:id="selectedPathField"
                                                           editable="false"
                                                           promptText="The executable path will appear here"
                                                           GridPane.columnIndex="1"
                                                           GridPane.rowIndex="1"/>

                                                <Label styleClass="field-label" text="Arguments" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                                                <TextField fx:id="selectedArgumentsField"
                                                           editable="false"
                                                           promptText="Optional launch arguments"
                                                           GridPane.columnIndex="1"
                                                           GridPane.rowIndex="2"/>

                                                <Label styleClass="field-label" text="Notes" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                                                <TextArea fx:id="selectedNotesArea"
                                                          editable="false"
                                                          prefRowCount="4"
                                                          promptText="Optional notes"
                                                          styleClass="notes-area"
                                                          wrapText="true"
                                                          GridPane.columnIndex="1"
                                                          GridPane.rowIndex="3"/>
                                            </children>
                                        </GridPane>
                                    </children>
                                </VBox>

                                <VBox spacing="14" styleClass="panel-card">
                                    <children>
                                        <VBox spacing="2">
                                            <children>
                                                <Label styleClass="section-title" text="Proxy and Launch Settings"/>
                                                <Label styleClass="section-subtitle"
                                                       text="Choose whether to reuse the default proxy, enter a custom one, or launch without proxy variables."
                                                       wrapText="true"/>
                                            </children>
                                        </VBox>

                                        <GridPane hgap="12" vgap="12">
                                            <columnConstraints>
                                                <ColumnConstraints minWidth="116"/>
                                                <ColumnConstraints hgrow="ALWAYS"/>
                                            </columnConstraints>
                                            <children>
                                                <Label styleClass="field-label" text="Default Proxy" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                                                <TextField fx:id="defaultProxyField"
                                                           onAction="#handleDefaultProxyCommit"
                                                           promptText="http://127.0.0.1:7890"
                                                           GridPane.columnIndex="1"
                                                           GridPane.rowIndex="0"/>

                                                <Label styleClass="hint-text"
                                                       text="Accepted formats: http://host:port, https://host:port, or socks5://host:port."
                                                       wrapText="true"
                                                       GridPane.columnIndex="1"
                                                       GridPane.rowIndex="1"/>

                                                <Label styleClass="field-label" text="Custom Proxy" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                                                <TextField fx:id="customProxyField"
                                                           promptText="socks5://127.0.0.1:1080"
                                                           GridPane.columnIndex="1"
                                                           GridPane.rowIndex="2"/>

                                                <Label styleClass="field-label" text="Mode" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                                                <ChoiceBox fx:id="modeChoiceBox"
                                                           prefWidth="230"
                                                           GridPane.columnIndex="1"
                                                           GridPane.rowIndex="3"/>

                                                <Label fx:id="modeDescriptionLabel"
                                                       styleClass="hint-text"
                                                       text="Use the saved default proxy for this launch."
                                                       wrapText="true"
                                                       GridPane.columnIndex="1"
                                                       GridPane.rowIndex="4"/>
                                            </children>
                                        </GridPane>
                                    </children>
                                </VBox>
                            </children>
                        </VBox>
                    </content>
                </ScrollPane>
            </items>
        </SplitPane>
    </center>

    <bottom>
        <VBox spacing="12" BorderPane.alignment="CENTER_LEFT">
            <children>
                <BorderPane styleClass="panel-card launch-card">
                    <left>
                        <VBox spacing="2" BorderPane.alignment="CENTER_LEFT">
                            <children>
                                <Label styleClass="section-title" text="Launch"/>
                                <Label styleClass="section-subtitle"
                                       text="Proxy Launcher passes environment variables through a Windows shell start command. The target application must support those variables for the proxy to take effect."
                                       wrapText="true"/>
                            </children>
                        </VBox>
                    </left>
                    <right>
                        <FlowPane alignment="CENTER_RIGHT" hgap="10" vgap="10" BorderPane.alignment="CENTER_RIGHT">
                            <children>
                                <Button mnemonicParsing="false"
                                        onAction="#handleOpenLogFolder"
                                        styleClass="secondary-button"
                                        text="Open Log Folder"/>
                                <Button fx:id="launchButton"
                                        mnemonicParsing="false"
                                        onAction="#handleLaunch"
                                        styleClass="primary-button"
                                        text="Launch Application"/>
                            </children>
                        </FlowPane>
                    </right>
                </BorderPane>

                <HBox fx:id="statusBar"
                      alignment="CENTER_LEFT"
                      spacing="10"
                      styleClass="status-panel status-info">
                    <children>
                        <Label styleClass="status-heading" text="Status"/>
                        <Label fx:id="statusLabel" styleClass="status-message" text="Ready." wrapText="true"/>
                    </children>
                </HBox>
            </children>
        </VBox>
    </bottom>
</BorderPane>
